# Copy thành .env ở root repo rồi điền giá trị (PLAN.md 3.4).
# LLM key CHỈ tồn tại trên server — không bao giờ đưa xuống máy khách.
DEEPSEEK_API_KEY=sk-...

# Các biến dưới đây có mặc định hợp lý — chỉ mở comment khi cần đổi.
# LLM_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-chat
# DATA_DIR=./data
# MAX_CONCURRENT_RUNS=3
# RUN_TIMEOUT_SECONDS=600  # trần thời gian 1 run; nới cho lô tra nhiều creator
# TOOL_CALL_TIMEOUT_SECONDS=120
# PORT=8000
