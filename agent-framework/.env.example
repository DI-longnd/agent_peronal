DEEPSEEK_API_KEY=sk-your-key-here

# File JSON lưu cookie + localStorage sau khi đăng nhập (Playwright storageState) —
# KHÔNG phải toàn bộ profile Chrome. Được TẠO bởi scripts/setup_browser_login.py
# (đăng nhập thủ công 1 lần, ngoài agent), agent chỉ đọc lại để dùng session có sẵn.
BROWSER_STORAGE_STATE=./.auth/state.json

# true = chạy ẩn (không thấy cửa sổ Chrome); để trống hoặc false khi cần tự đăng nhập thủ công
BROWSER_HEADLESS=false
